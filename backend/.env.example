# ---- Gemini (Google AI Studio) ----
LLM_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=your_google_api_key_here

# ---- OpenAI (via LiteLLM) ----
# LLM_MODEL=litellm:openai/gpt-4o
# OPENAI_API_KEY=your_openai_api_key_here

# ---- Anthropic (via LiteLLM) ----
# LLM_MODEL=litellm:anthropic/claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---- Amazon Bedrock (via LiteLLM) ----
# Prerequisite: install boto3 and botocore[crt] in addition to the base dependencies.
#   pip install boto3 "botocore[crt]"
# LLM_MODEL=litellm:bedrock/global.anthropic.claude-sonnet-4-6
# AWS_BEARER_TOKEN_BEDROCK=xxxxxxxxx

# ---- Server settings ----
HOST=0.0.0.0
PORT=8000
# Enables uvicorn autoreload. Only affects `python -m backend.main`; the
# documented `uv run uvicorn main:app --reload` command and the Dockerfile's
# startup path are unaffected either way. Defaults to false.
# RELOAD=true

# ---- CORS ----
# Comma-separated list of allowed origins for /chat and /sessions.
# Add each frontend origin that should be permitted to call the API.
# '*' is rejected at startup: allow_credentials=True is always enabled, and
# the CORS spec forbids pairing a wildcard origin with credentialed requests.
CORS_ORIGINS=http://localhost:3000

# ---- Database ----
# Database URL for REST API data and ADK session storage (both share the same
# database). SQLite is the zero-config default; point this at PostgreSQL to
# switch backends. The async driver suffix (aiosqlite / asyncpg) is added
# automatically, so the plain scheme is enough.
DB_URL=sqlite:///a2flow.db
# DB_URL=postgresql://user:password@localhost:5432/a2flow

# ---- Admin user ----
# Password for the initial 'admin' user auto-created on first startup.
# Only used while the database has no real users yet.
# If unset, a random password is generated and logged once (at WARNING
# level) to the backend's startup output - see `docker compose logs backend`.
# It cannot be recovered afterwards, so set this explicitly for anything
# beyond local experimentation.
# ADMIN_PASSWORD=change-me-now-123

# ---- Authentication ----
# Sliding idle timeout (seconds) for a login session. Each authenticated request
# refreshes the window; a session left idle longer than this is rejected.
# Defaults to 28800 (8 hours).
# SESSION_IDLE_TIMEOUT_SECONDS=28800
# Set to true to mark the session/CSRF cookies as Secure (HTTPS only).
# Leave false for local HTTP development. Defaults to false.
# SESSION_COOKIE_SECURE=false

# ---- Secret management ----
# Key used to Fernet-encrypt local secrets stored in the database.
# Resolution precedence:
#   1. SECRET_ENCRYPTION_KEY (must be a valid Fernet key; generate one with
#      `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`)
#   2. The key file at SECRET_KEY_FILE (defaults to .secret_key next to the
#      SQLite database file, or the working directory for other databases)
#   3. A key is generated, saved to that file, and a WARNING is logged.
# Back the key up: losing it makes every stored local secret undecryptable.
# SECRET_ENCRYPTION_KEY=
# SECRET_KEY_FILE=.secret_key

# ---- HashiCorp Vault (optional, for vault-type secrets) ----
# Single global connection; only the KV v2 engine is supported.
# AppRole credentials take precedence over the static token when both are set.
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=hvs.xxxxxxxx
# VAULT_ROLE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# VAULT_SECRET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# VAULT_APPROLE_MOUNT=approle

# ---- Agent skill store ----
# Root of the store Agent Skill repositories are shallow-cloned into, laid out
# as <skill_id>/<commit_sha>/. This is durable state, not a cache: a workflow
# session pins the revision it started with, so wiping it leaves existing
# sessions unable to load their skill until an admin pulls it again. Running
# more than one backend replica requires all of them to share this directory.
# Defaults to backend/.skills (relative to the working dir).
# SKILLS_DIR=.skills

# How long an unreferenced skill revision directory is kept before a pull may
# prune it. Defaults to 3600 (1 hour).
# SKILLS_PRUNE_GRACE_SECONDS=3600

# Per-request (connect/read) timeout, in seconds, for a skill clone's HTTP
# requests. Bounds how long a slow or hanging remote can stall a clone, which
# otherwise holds the skill's sync advisory lock indefinitely. Defaults to 120.
# SKILLS_CLONE_TIMEOUT_SECONDS=120

# ---- MCP registry ----
# Base URL of the official MCP registry used to search for installable servers.
# Defaults to https://registry.modelcontextprotocol.io.
# MCP_REGISTRY_URL=https://registry.modelcontextprotocol.io

# ---- Agent settings ----
# Role description passed to schema_manager.generate_system_prompt().
# The full system prompt is assembled from this plus A2UI workflow rules and schema.
ROLE_DESCRIPTION="You are a helpful assistant. Answer concisely and clearly."
