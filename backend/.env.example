# ---- Gemini (Google AI Studio) ----
LLM_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=your_google_api_key_here

# ---- OpenAI (via LiteLLM) ----
# LLM_MODEL=litellm:openai/gpt-4o
# OPENAI_API_KEY=your_openai_api_key_here

# ---- Anthropic (via LiteLLM) ----
# LLM_MODEL=litellm:anthropic/claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---- Amazon Bedrock (via LiteLLM) ----
# Prerequisite: install boto3 and botocore[crt] in addition to the base dependencies.
#   pip install boto3 "botocore[crt]"
# LLM_MODEL=litellm:bedrock/global.anthropic.claude-sonnet-4-6
# AWS_BEARER_TOKEN_BEDROCK=xxxxxxxxx

# ---- Server settings ----
HOST=0.0.0.0
PORT=8000

# ---- CORS ----
# Comma-separated list of allowed origins for /chat and /sessions.
# Add each frontend origin that should be permitted to call the API.
CORS_ORIGINS=http://localhost:3000

# ---- Database ----
# SQLite database URL for REST API data and ADK session storage.
# Both engines share the same file. Defaults to a2flow.db in the working directory.
DB_URL=sqlite:///a2flow.db

# ---- Admin user ----
# Password for the initial 'admin' user auto-created on first startup.
# Only used while the database has no real users yet. Minimum 12 characters.
# Defaults to "admin12345678" when unset.
# ADMIN_PASSWORD=change-me-now-123

# ---- Agent settings ----
# Role description passed to schema_manager.generate_system_prompt().
# The full system prompt is assembled from this plus A2UI workflow rules and schema.
ROLE_DESCRIPTION="You are a helpful assistant. Answer concisely and clearly."
