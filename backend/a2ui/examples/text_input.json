[
  {
    "version": "v0.9",
    "createSurface": {
      "surfaceId": "input-surface",
      "catalogId": "https://a2ui.org/specification/v0_9/basic_catalog.json"
    }
  },
  {
    "version": "v0.9",
    "updateDataModel": {
      "surfaceId": "input-surface",
      "path": "/",
      "value": {
        "name": "",
        "message": ""
      }
    }
  },
  {
    "version": "v0.9",
    "updateComponents": {
      "surfaceId": "input-surface",
      "components": [
        {
          "component": "Card",
          "id": "root",
          "child": "form-col"
        },
        {
          "component": "Column",
          "id": "form-col",
          "children": ["form-title", "name-field", "message-field", "submit-btn"]
        },
        {
          "component": "Text",
          "id": "form-title",
          "text": "Send a Message",
          "variant": "h3"
        },
        {
          "component": "TextField",
          "id": "name-field",
          "label": "Your Name",
          "variant": "shortText",
          "value": { "path": "/name" }
        },
        {
          "component": "TextField",
          "id": "message-field",
          "label": "Message",
          "variant": "longText",
          "value": { "path": "/message" }
        },
        {
          "component": "Button",
          "id": "submit-btn",
          "variant": "secondary",
          "child": "submit-label",
          "action": {
            "event": {
              "name": "submit_message",
              "context": {
                "name": { "path": "/name" },
                "message": { "path": "/message" }
              }
            }
          }
        },
        {
          "component": "Text",
          "id": "submit-label",
          "text": "Send"
        }
      ]
    }
  }
]
